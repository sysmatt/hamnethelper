<?php
// Copy this file to hamnethelper-config.php in the docroot, ONE LEVEL ABOVE the hamnethelper/
// directory. Example: if hamnethelper is cloned to /var/www/html/hamnethelper/, place this file
// at /var/www/html/hamnethelper-config.php
//
// This keeps your server-specific config outside the git repo so shallow clones/pulls never
// overwrite it. Any key you omit falls back to the default in lib/config.php.
//
// This file must `return` a plain associative array (no defines, no output) — see lib/config.php.

return [

    // --- Paths & hamdat integration -----------------------------------------------------------

    // Full path to the hamdat binary (used for the second-level lookup, see SPEC.md §3.3)
    'hamdat_bin' => '/usr/local/bin/hamdat',

    // Full path to the hamdat SQLite database
    'hamdat_db' => '/home/ubuntu/.hamdat/hamdat.db',

    // If hamdat needs its dependencies (requests, pgeocode) from a specific Python venv rather
    // than whatever python3 the web server's PATH resolves to, set this to that venv's python
    // binary -- it's invoked explicitly as the interpreter instead of relying on hamdat's own
    // `#!/usr/bin/env python3` shebang. Leave unset if hamdat runs fine on its own.
    'hamdat_python_bin' => '/home/hamdat/venv/bin/python3',

    // Writable temp directory used briefly when generating hamdat query output. Defaults to
    // sys_get_temp_dir() if omitted -- override only if that default isn't writable by the web
    // server user.
    // 'hamdat_temp_dir' => '/tmp',

    // Directory where net JSON files are stored. MUST be outside the docroot and writable by
    // the web server user (e.g. www-data). See SPEC.md §2.
    'nets_dir' => '/var/lib/hamnethelper/nets',

    // --- Branding ------------------------------------------------------------------------------

    'app_name' => 'HamNetHelper',

    // --- Net types -------------------------------------------------------------------------
    // Shown as a dropdown on the net creation form (SPEC.md §4). Add/remove/rename entries here
    // with no code changes required — 'value' is what's stored in each net's JSON file, 'label'
    // is what the operator sees.

    'net_types' => [
        ['value' => 'weekly',  'label' => 'Weekly'],
        ['value' => 'ares',    'label' => 'Emergency / ARES'],
        ['value' => 'drill',   'label' => 'Drill / Training'],
        ['value' => 'special', 'label' => 'Special Event'],
        ['value' => 'other',   'label' => 'Other'],
    ],

    // --- Behavior tuning -------------------------------------------------------------------

    // Default radius (miles) pre-filled in the HAMDAT Lookup Settings dialog for new nets.
    'default_hamdat_radius_miles' => 25,

    // How long (ms) the browser waits after the last edit before autosaving (SPEC.md §2).
    'autosave_debounce_ms' => 800,

    // Max size (bytes) accepted for an uploaded participant-list text file.
    'roster_upload_max_bytes' => 65536,

    // Max number of ranked matches shown in the callsign/name lookup dropdown (SPEC.md §5.1).
    'lookup_suggestion_limit' => 15,

    // 'dark' or 'light' — the theme shown before the operator's own localStorage preference
    // (if any) is applied.
    'default_theme' => 'dark',

];
